# ============================================================
# All environment variables for the Romina learning portal.
#
# This single file is a master reference. The variables are split
# across THREE deployment targets — copy each section to the right
# place when deploying:
#
#   [1] FRONTEND  → .env (local) / Vercel project env vars
#   [2] RAILWAY   → services/yt-dlp-service/.env (local) / Railway dashboard
#   [3] SUPABASE  → `supabase secrets set KEY=value --project-ref <ref>`
#
# Lines marked "(auto)" are set automatically by the platform — do not
# duplicate. Lines marked "(optional)" can be left blank.
# ============================================================


# ============================================================
# [1] FRONTEND — Vite build-time vars
# Put these in: .env  (and in Vercel → Project → Environment Variables)
# ============================================================

# Supabase project the frontend talks to
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase anon/publishable key>
VITE_SUPABASE_ANON_KEY=<same value as VITE_SUPABASE_PUBLISHABLE_KEY>

# Railway yt-dlp service URL (from section [2] after deploy)
VITE_TRANSCRIBE_SERVICE_URL=https://<your-service>.up.railway.app

# Tenant overrides — leave blank to use the default constant
# (00000000-0000-0000-0000-000000000000)
VITE_TENANT_ID=
VITE_TENANT_SLUG=

# Demo mode: mocks Supabase auth/db in the browser so the UI works
# without a live backend. Sign in with demo@learning.local / demo1234.
# Set to "true" to enable, leave blank for production.
VITE_DEMO_MODE=

# Sentry error tracking (optional)
VITE_SENTRY_DSN=
VITE_RELEASE=

# Require MFA for admin users (optional, defaults to false)
VITE_REQUIRE_MFA_FOR_ADMINS=


# ============================================================
# [2] RAILWAY — yt-dlp transcription service
# Put these in: Railway dashboard → Service → Variables
# (also copy to services/yt-dlp-service/.env for local docker testing)
# ============================================================

# Supabase project (same project as the frontend)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<supabase anon key>
SUPABASE_SERVICE_ROLE_KEY=<supabase service-role key — SECRET, server-only>

# Speech-to-text provider
ASSEMBLYAI_API_KEY=<from assemblyai.com>

# LLM for lesson summarization
OPENAI_API_KEY=<from platform.openai.com>

# PORT is set automatically by Railway — do not override


# ============================================================
# [3] SUPABASE EDGE FUNCTIONS — secrets
# Set via: supabase secrets set KEY=value --project-ref <ref>
# (SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY are
#  auto-injected by Supabase — do NOT set them manually)
# ============================================================

# --- AI providers ---
GEMINI_API_KEY=<from ai.google.dev — used by ai-assistant, kg-*, transcribe-lesson>
ANTHROPIC_API_KEY=<from console.anthropic.com — optional, used by some AI flows>

# --- Knowledge Graph service (external VPS) ---
# The KG service is NOT in this repo. It runs on a separate VPS.
# Leave blank if you don't have a KG service deployed yet — the
# AI assistant (FloatingAiChat) will return errors without it.
KG_API_URL=https://<kg-vps-host>
KG_API_TOKEN=<token issued by your KG service>
KG_WEBHOOK_SECRET=<random string, must match the value on the KG VPS>

# --- yt-dlp helper (called by transcribe-lesson edge function for Vimeo) ---
# Points to the same Railway service from section [2].
# YTDLP_SERVICE_KEY is optional bearer auth (only if you add auth to the service).
YTDLP_SERVICE_URL=https://<your-service>.up.railway.app
YTDLP_SERVICE_KEY=

# --- Transactional email (Resend) ---
RESEND_API_KEY=<from resend.com>
INVITE_FROM_EMAIL=invites@<your-domain>
INVITE_REPLY_TO=support@<your-domain>
INVITE_SITE_URL=https://<your-vercel-domain>
INVITE_LOGO_URL=https://<your-vercel-domain>/logo.svg

# --- Web Push notifications (VAPID) ---
# Generate with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=<vapid public key>
VAPID_PRIVATE_KEY=<vapid private key — SECRET>
VAPID_SUBJECT=mailto:admin@<your-domain>

# --- Audit / webhook signing ---
# Random ≥32-char string used to HMAC-sign internal audit webhook calls
AUDIT_WEBHOOK_INTERNAL_SECRET=<random secret>
# Comma-separated list of allowed webhook destination hosts
AUDIT_WEBHOOK_ALLOWED_HOSTS=

# --- Scheduled jobs ---
# Random secret that pg_cron sends in the Authorization header
CRON_SECRET=<random secret>

# --- Google Calendar integration (optional) ---
GOOGLE_CALENDAR_URL=

# --- CORS ---
# Comma-separated list of origins allowed to call edge functions
# e.g. https://app.romina.example,https://staging.romina.example
ALLOWED_ORIGINS=
